{
	"schemaVersion": 1,
	"id": "official-server-list",
	"version": "${version}",
	"name": "Official Server List",
	"description": "Integrates the official Minecraft server list into the multiplayer menu.",
	"authors": [
		"jonbarrow"
	],
	"contact": {
		"homepage": "https://github.com/jonbarrow/minecraft-official-server-list-mod",
		"issues": "https://github.com/jonbarrow/minecraft-official-server-list-mod/issues",
		"sources": "https://github.com/jonbarrow/minecraft-official-server-list-mod"
	},
	"license": "LGPL-3.0-only",
	"icon": "assets/official-server-list/icon.png",
	"environment": "*",
	"entrypoints": {
